```
def validate_parsed_input(data: dict) -> dict:
    """파싱된 입력값을 검증하고 피드백 제공"""
    
    errors = []    # 필수 누락 → 진행 불가
    warnings = []  # 선택 누락 → 기본값 적용
    
    # ── 필수 항목 체크 ──
    required = {
        "sender": "발신자",
        "receiver": "수신자", 
        "purpose": "목적",
        "requests": "핵심 요청사항"
    }
    
    for key, label in required.items():
        if key not in data or not data[key]:
            errors.append(f"❌ [{label}]이(가) 비어있습니다.")
    
    # 요청사항이 리스트인 경우 빈 리스트 체크
    if "requests" in data and len(data["requests"]) == 0:
        errors.append("❌ [핵심 요청사항]을 최소 1개 입력해주세요.")
    
    # ── 선택 항목 기본값 처리 ──
    if "tone" not in data or not data["tone"]:
        data["tone"] = "공손"
        warnings.append("ℹ️ 톤이 지정되지 않아 '공손'으로 설정합니다.")
    
    # 톤 유효성 체크
    valid_tones = ["공손", "격식", "캐주얼"]
    if data.get("tone") and data["tone"] not in valid_tones:
        errors.append(
            f"❌ 톤은 {valid_tones} 중 하나여야 합니다. "
            f"입력값: '{data['tone']}'"
        )
    
    # 마감일 형식 체크
    if data.get("deadline") and data["deadline"] != "없음":
        date_pattern = r"^\d{4}-\d{2}-\d{2}$"
        if not re.match(date_pattern, data["deadline"]):
            warnings.append(
                f"⚠️ 마감일 형식이 YYYY-MM-DD가 아닙니다. "
                f"입력값: '{data['deadline']}'"
            )
    
    return {
        "valid": len(errors) == 0,
        "errors": errors,
        "warnings": warnings,
        "data": data
    }


# 테스트: 정상 입력
result = validate_parsed_input(parsed)
print(f"유효: {result['valid']}")
print(f"경고: {result['warnings']}")
```

