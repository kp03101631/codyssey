python📋 복사

```
def persona_decision(situation: str, data: dict) -> dict:
    """수진 페르소나의 판단 로직"""
    
    decisions = {
        "missing_required": {
            "can_generate": False,
            "action": "ask_back",
            "priority": "정확성"
        },
        "missing_optional": {
            "can_generate": True,
            "action": "skip_field",
            "priority": "간결함"
        },
        "over_300_chars": {
            "can_generate": True,
            "action": "summarize",
            "priority": "간결함"
        },
        "past_deadline": {
            "can_generate": True,
            "action": "warn_and_generate",
            "priority": "정확성",
            "warning": "⚠️ 입력하신 마감일이 이미 지난 날짜입니다. 확인해주세요."
        },
        "out_of_scope": {
            "can_generate": False,
            "action": "reject",
            "priority": "정확성"
        }
    }
    
    return decisions.get(situation, {
        "can_generate": False,
        "action": "ask_back"
    })
```

