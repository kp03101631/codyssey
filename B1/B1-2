def validate_output(output: str, input_data: dict) -> dict:
    """생성된 메일이 성공 기준을 충족하는지 검증"""
    
    results = {}
    
    # 기준 1: 글자 수 체크 (본문만)
    body = output.split("---")[1] if "---" in output else output
    char_count = len(body.replace("\n", "").replace(" ", ""))
    results["length_ok"] = char_count <= 300
    results["char_count"] = char_count
    
    # 기준 2: 필수 정보 포함 여부
    results["has_sender"] = input_data["sender"].split()[-1] in output
    results["has_receiver"] = input_data["receiver"].split()[-1] in output
    results["has_purpose"] = any(
        keyword in output 
        for keyword in input_data["purpose"].split()
    )
    
    # 기준 3: 마감일 반영 여부
    if input_data.get("deadline"):
        results["has_deadline"] = input_data["deadline"] in output
    
    # 기준 4: 구조 체크 (인사로 시작하는지)
    greetings = ["안녕하십니까", "안녕하세요"]
    results["has_greeting"] = any(g in output for g in greetings)
    
    # 종합 판정
    results["pass"] = all(
        v for k, v in results.items() 
        if k != "char_count"
    )
    
    return results
```

