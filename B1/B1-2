## 3단계: 실제 구현 코드

python📋 복사

```
import openai

class MailDraftGenerator:
    """업무 메일 초안 자동 생성기"""
    
    def __init__(self, api_key: str):
        self.client = openai.OpenAI(api_key=api_key)
        self.system_prompt = SYSTEM_PROMPT  # 위에서 정의한 시스템 프롬프트
    
    def validate_input(self, mail_input: dict) -> list:
        """입력값 검증 - 누락된 필드 체크"""
        required_fields = ["sender", "receiver", "purpose", "request"]
        missing = []
        for field in required_fields:
            if field not in mail_input or not mail_input[field]:
                missing.append(field)
        return missing
    
    def generate_draft(self, mail_input: dict) -> str:
        """메일 초안 생성"""
        
        # 1. 입력값 검증
        missing = self.validate_input(mail_input)
        if missing:
            return f"⚠️ 필수 항목이 누락되었습니다: {', '.join(missing)}"
        
        # 2. 프롬프트 구성
        user_prompt = build_user_prompt(mail_input)
        
        # 3. LLM 호출
        response = self.client.chat.completions.create(
            model="gpt-4o",
            messages=[
                {"role": "system", "content": self.system_prompt},
                {"role": "user", "content": user_prompt}
            ],
            temperature=0.3,  # 일관성을 위해 낮은 temperature
            max_tokens=1000
        )
        
        return response.choices[0].message.content


# 사용 예시
generator = MailDraftGenerator(api_key="your-api-key")

result = generator.generate_draft({
    "sender": "김철수 / 마케팅팀 대리",
    "receiver": "박영희 / 개발팀 팀장",
    "purpose": "신규 기능 개발 협조 요청",
    "details": "랜딩페이지 A/B 테스트 기능 추가 개발 필요",
    "request": "개발 일정 확인 및 미팅 일정 조율",
    "deadline": "2025-01-20",
    "tone": "formal",
    "urgency": "medium"
})

print(result)
```

