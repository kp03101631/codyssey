```
import re

def parse_mail_input(raw_text: str) -> dict:
    """사용자 입력 텍스트를 구조화된 딕셔너리로 변환"""
    
    result = {}
    
    # 각 필드를 정규식으로 추출
    patterns = {
        "sender":   r"발신자:\s*(.+)",
        "receiver": r"수신자:\s*(.+)",
        "purpose":  r"목적:\s*(.+)",
        "deadline": r"마감일:\s*(.+)",
        "tone":     r"톤:\s*(.+)",
        "note":     r"추가 참고사항:\s*(.+)",
    }
    
    for key, pattern in patterns.items():
        match = re.search(pattern, raw_text)
        if match:
            result[key] = match.group(1).strip()
    
    # 요청사항은 여러 줄이므로 별도 처리
    requests = re.findall(r"\d+\)\s*(.+)", raw_text)
    result["requests"] = requests
    
    return result


# 테스트
